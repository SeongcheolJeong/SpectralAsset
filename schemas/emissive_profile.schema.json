{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectralasset.local/schemas/emissive_profile.schema.json",
  "type": "object",
  "required": [
    "id",
    "spd_ref",
    "state_map",
    "nominal_luminance_cd_m2",
    "temperature_c",
    "driver_mode",
    "source_quality",
    "source_ids",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "spd_ref": {},
    "state_map": {
      "type": "object"
    },
    "nominal_luminance_cd_m2": {},
    "temperature_c": {
      "type": "number"
    },
    "driver_mode": {
      "type": "string"
    },
    "source_quality": {
      "type": "string",
      "enum": [
        "measured_standard",
        "measured_derivative",
        "vendor_derived",
        "project_proxy"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reference_curve_refs": {
      "type": "object"
    },
    "derivation_method": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    },
    "license": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
