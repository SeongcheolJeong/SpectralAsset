{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectralasset.local/schemas/camera_profile.schema.json",
  "type": "object",
  "required": [
    "id",
    "sensor_branch",
    "wavelength_grid_ref",
    "raw_channel_srf_refs",
    "effective_channel_srf_refs",
    "normalization",
    "operating_temperature_c",
    "source_quality",
    "source_ids",
    "license",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "profile_family": {
      "type": "string",
      "enum": [
        "generic_reference"
      ]
    },
    "sensor_branch": {
      "type": "string",
      "enum": [
        "rgb",
        "rgb_nir"
      ]
    },
    "wavelength_grid_ref": {
      "type": "string"
    },
    "raw_channel_srf_refs": {
      "type": "object"
    },
    "optics_transmittance_ref": {
      "type": "object"
    },
    "channel_optics_transmittance_refs": {
      "type": "object"
    },
    "reference_curve_refs": {
      "type": "object"
    },
    "effective_channel_srf_refs": {
      "type": "object"
    },
    "derivation_method": {
      "type": "object"
    },
    "replaces_profile_id": {
      "type": "string"
    },
    "normalization": {
      "type": "object"
    },
    "operating_temperature_c": {
      "type": "number"
    },
    "source_quality": {
      "type": "string",
      "enum": [
        "measured_standard",
        "measured_derivative",
        "vendor_derived",
        "project_proxy"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "anyOf": [
    {
      "required": [
        "optics_transmittance_ref"
      ]
    },
    {
      "required": [
        "channel_optics_transmittance_refs"
      ]
    }
  ],
  "additionalProperties": true
}
