{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spectralasset.local/schemas/camera_profile.schema.json",
  "type": "object",
  "required": [
    "id",
    "sensor_branch",
    "wavelength_grid_ref",
    "normalization",
    "operating_temperature_c",
    "source_quality",
    "source_ids",
    "license",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "profile_family": {
      "type": "string",
      "enum": [
        "generic_reference",
        "measured_capture"
      ]
    },
    "response_model": {
      "type": "string",
      "enum": [
        "derived_raw_optics",
        "measured_system_srf"
      ]
    },
    "sensor_branch": {
      "type": "string",
      "enum": [
        "rgb",
        "rgb_nir"
      ]
    },
    "wavelength_grid_ref": {
      "type": "string"
    },
    "raw_channel_srf_refs": {
      "type": "object"
    },
    "optics_transmittance_ref": {
      "type": "object"
    },
    "channel_optics_transmittance_refs": {
      "type": "object"
    },
    "reference_curve_refs": {
      "type": "object"
    },
    "active_channel_srf_refs": {
      "type": "object"
    },
    "effective_channel_srf_refs": {
      "type": "object"
    },
    "derivation_method": {
      "type": "object"
    },
    "replaces_profile_id": {
      "type": "string"
    },
    "sensor_identity": {
      "type": "object"
    },
    "measurement_conditions": {
      "type": "object"
    },
    "normalization": {
      "type": "object"
    },
    "operating_temperature_c": {
      "type": "number"
    },
    "source_quality": {
      "type": "string",
      "enum": [
        "measured_standard",
        "measured_derivative",
        "vendor_derived",
        "project_proxy"
      ]
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "object"
    },
    "provenance": {
      "type": "object"
    }
  },
  "anyOf": [
    {
      "required": [
        "response_model",
        "raw_channel_srf_refs",
        "effective_channel_srf_refs"
      ],
      "anyOf": [
        {
          "required": [
            "optics_transmittance_ref"
          ]
        },
        {
          "required": [
            "channel_optics_transmittance_refs"
          ]
        }
      ]
    },
    {
      "required": [
        "response_model",
        "active_channel_srf_refs",
        "sensor_identity",
        "measurement_conditions"
      ]
    }
  ],
  "additionalProperties": true
}
