#usda 1.0
(
    defaultPrim = "Preview"
    metersPerUnit = 1
    upAxis = "Y"
)

def Xform "Preview"
{
    def Xform "Asset"
    (
        prepend references = @../../../../exports/usd/signal_vehicle_vertical_3_aspect.usdc@
    )
    {
        double3 xformOp:rotateXYZ = (0, -22, 0)
        uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
    }

    def Camera "RenderCam"
    {
        float focalLength = 38
        float horizontalAperture = 20.955
        float verticalAperture = 15.2908
        double3 xformOp:translate = (0.0, 1.8, 2.2)
        double3 xformOp:rotateXYZ = (-3, 0, 0)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
    }
}
